{
  "stagename": "working-files/visibility-",
  "header-comment": "*****************************************************************************************************************************************************\n*                                                                                                                                                   *\n*  This script makes all of the required changes to add 'Visibility' to your PAN-OS XML configuration file.                                         *\n*             (To achieve ‘Visibility’ the script can be used 'as is' without any changes).                                                         *\n*                                                                                                                                                   *\n*  This script will need you to only do the following two things;                                                                                   *\n*    i) Rename the input file referenced in the first pan-os-php command below to be the XML configuration file being used (eg: example_panos.xml). *\n*    ii) Copy the input file from the above (ie: example_panos.xml) to the pan-os-php staging directory so that it can be referenced by this script.*\n*                                                                                                                                                   *\n*****************************************************************************************************************************************************\n\n*****************************************************************************************************************************************************\n*                                                                                                                                                   *\n*  The script will now begin and will run a sequence of pan-os-php commands.                                                                        *\n*  Each new command will use the outputfile of the previous command as the input file of the new command.                                           *\n*  The final xml file generated by the last command in this script should then be imported, and then loaded into the PAN-OS firewall.               *\n*                                                                                                                                                   *\n*****************************************************************************************************************************************************",
  "footer-comment": "*****************************************************************************************************************************************************\n*                                                                                                                                                   *\n*   VISIBILITY playbook FINALISED                                                                                                                   *\n*                                                                                                                                                   *\n*****************************************************************************************************************************************************",
  "command": [
    {
      "type": "zone",
      "actions": "actions=exportToExcel:1a_NoZPP_UsedinZone.html",
      "filter": "filter=!(zpp is.set)",
      "location": "location=any"
    },
    {
      "type": "zone",
      "actions": "actions=exportToExcel:1b_NoLFP_UsedinZone.html",
      "filter": "filter=!(logprof is.set)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:2_NoLFP_UsedinRule.html",
      "filter": "filter=!(logprof is.set) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:3a_NoSPG_in_AllowRule.html",
      "filter": "filter=!(secprof is.set) and (action is.allow) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:3b_SPG_Undefined_in_AllowRule.html",
      "filter": "filter=(secprof group.is.undefined) and (action is.allow) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:4a_NoVP_in_AllowRule.html",
      "filter": "filter=(secprof type.is.profile) and !(secprof vuln-profile.is.set) and (action is.allow)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:4b_NoAS_in_AllowRule.html",
      "filter": "filter=(secprof type.is.profile) and !(secprof as-profile.is.set) and (action is.allow)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:4c_NoAV_in_AllowRule.html",
      "filter": "filter=(secprof type.is.profile) and !(secprof av-profile.is.set) and (action is.allow)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:4d_NoURL_in_AllowRule.html",
      "filter": "filter=(secprof type.is.profile) and !(secprof url-profile.is.set) and (action is.allow)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:4e_NoFB_in_AllowRule.html",
      "filter": "filter=(secprof type.is.profile) and !(secprof file-profile.is.set) and (action is.allow)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:4f_NoWF_in_AllowRule.html",
      "filter": "filter=(secprof type.is.profile) and !(secprof wf-profile.is.set) and (action is.allow)",
      "location": "location=any"
    },
    {
      "type": "securityprofilegroup",
      "actions": "actions=exportToExcel:5a_NoAV_Exists_in_SPG.html,adoption|visibility|bestpractice",
      "filter": "filter=!(secprof av-profile.is.set )",
      "location": "location=any"
    },
    {
      "type": "securityprofilegroup",
      "actions": "actions=exportToExcel:5b_NoVP_Exists_in_SPG.html,adoption|visibility|bestpractice",
      "filter": "filter=!(secprof vuln-profile.is.set )",
      "location": "location=any"
    },
    {
      "type": "securityprofilegroup",
      "actions": "actions=exportToExcel:5c_NoURL_Exists_in_SPG.html,adoption|visibility|bestpractice",
      "filter": "filter=!(secprof url-profile.is.set )",
      "location": "location=any"
    },
    {
      "type": "securityprofilegroup",
      "actions": "actions=exportToExcel:5d_NoFB_Exists_in_SPG.html,adoption|visibility|bestpractice",
      "filter": "filter=!(secprof file-profile.is.set )",
      "location": "location=any"
    },
    {
      "type": "securityprofilegroup",
      "actions": "actions=exportToExcel:5e_NoAS_Exists_in_SPG.html,adoption|visibility|bestpractice",
      "filter": "filter=!(secprof as-profile.is.set )",
      "location": "location=any"
    },
    {
      "type": "securityprofilegroup",
      "actions": "actions=exportToExcel:5f_NoWF_Exists_in_SPG.html,adoption|visibility|bestpractice",
      "filter": "filter=!(secprof wf-profile.is.set )",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:6_SPG_exists_in_DenyRule.html",
      "filter": "filter=(secprof is.set) and !(action is.allow) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:7a_Log-at-End_Missing_inRule.html",
      "filter": "filter=!(log at.end) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:7b_Log-at-Start_inRule.html",
      "filter": "filter=(log at.start) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "ruletype": "ruletype=defaultsecurity",
      "actions": "actions=exportToExcel:8a_DefaultSec_NoLog-at-End.html",
      "filter": "filter=!(log at.end)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "ruletype": "ruletype=defaultsecurity",
      "actions": "actions=exportToExcel:8b_DefaultSec_No_LFP.html",
      "filter": "filter=!(logprof is.set)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "ruletype": "ruletype=defaultsecurity",
      "actions": "actions=exportToExcel:8c_DefaultSec_No_SPG-inAllow.html",
      "filter": "filter=!(secprof is.set) and (action is.allow)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "ruletype": "ruletype=defaultsecurity",
      "actions": "actions=exportToExcel:8d_DefaultSec_SPG-inDeny.html",
      "filter": "filter=(secprof is.set) and !(action is.allow)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:9a_Rule_is_Disabled.html",
      "filter": "filter=(rule is.disabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:9b_Rule_has_DoubleSpace.html",
      "filter": "filter=(name regex /  /)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:9c_block_applicationDefault.html",
      "filter": "filter=(service is.application-default) and !(action is.allow) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:9d_Rulename_contains_TestorTemp.html",
      "filter": "filter=((name contains test) or (name contains temp)) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:9e_Tag_contains_TestorTemp.html",
      "filter": "filter=((tag has.regex /temp/i ) or (tag has.regex /test/i )) and (rule is.enabled)",
      "location": "location=any"
    },
    {
      "type": "securityprofile",
      "securityprofiletype": "securityprofiletype=vulnerability",
      "actions": "actions=exportToExcel:9f-i_All_VP-SPs.html,UsedInLocation|WhereUsed|TotalUse|visibility|bestpractice",
      "location": "location=any"
    },
    {
      "type": "securityprofile",
      "securityprofiletype": "securityprofiletype=spyware",
      "actions": "actions=exportToExcel:9f-ii_All_AS-SPs.html,UsedInLocation|WhereUsed|TotalUse|visibility|bestpractice",
      "location": "location=any"
    },
    {
      "type": "securityprofile",
      "securityprofiletype": "securityprofiletype=virus",
      "actions": "actions=exportToExcel:9f-iii_All_AV-SPs.html,UsedInLocation|WhereUsed|TotalUse|visibility|bestpractice",
      "location": "location=any"
    },
    {
      "type": "securityprofile",
      "securityprofiletype": "securityprofiletype=url-filtering",
      "actions": "actions=exportToExcel:9f-iv_All_URL-SPs.html,UsedInLocation|WhereUsed|TotalUse|visibility|bestpractice",
      "location": "location=any"
    },
    {
      "type": "securityprofile",
      "securityprofiletype": "securityprofiletype=wildfire-analysis",
      "actions": "actions=exportToExcel:9f-v_All_WF-SPs.html,UsedInLocation|WhereUsed|TotalUse|visibility|bestpractice",
      "location": "location=any"
    },
    {
      "type": "securityprofilegroup",
      "actions": "actions=exportToExcel:9f-vi_SPG.html,UsedInLocation|TotalUse|visibility|bestpractice",
      "location": "location=any"
    },
    {
      "type": "threat-rule",
      "actions": "actions=exportToExcel:9f-vii_ThreatRules.html,UsedInLocation|WhereUsed",
      "location": "location=any"
    },
    {
      "type": "rule",
      "actions": "actions=exportToExcel:9g-i_All_sec_rules.html,visibility|bestpractice",
      "location": "location=any"
    },
    {
      "type": "rule",
      "ruletype": "ruletype=nat",
      "actions": "actions=exportToExcel:9g-ii_All_nat_rules.html",
      "location": "location=any"
    },
    {
      "type": "rule",
      "ruletype": "ruletype=decryption",
      "actions": "actions=exportToExcel:9g-iii_AllDecrypt_rules.html",
      "location": "location=any"
    },
    {
      "type": "zone",
      "actions": "actions=exportToExcel:9g-iv_All_Zones.html",
      "location": "location=any"
    },
    {
      "type": "address",
      "actions": "actions=exportToExcel:9h-i_Unused_Addresses.html,WhereUsed|UsedInLocation|ResolveIP|NestedMembers",
